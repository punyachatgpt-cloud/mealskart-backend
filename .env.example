# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key          # server-side only — never expose to clients
SUPABASE_ANON_KEY=your-anon-key                          # safe to expose in frontend
SUPABASE_JWT_SECRET=your-jwt-secret                      # from Supabase Dashboard → Settings → API → JWT Secret

# ── MSG91 (India DLT-compliant OTP SMS) ───────────────────────────────────────
# Supabase Auth custom SMS hook calls this service.
# Obtain from msg91.com — DLT registration required for Indian numbers.
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_TEMPLATE_ID=your-dlt-approved-template-id
MSG91_SENDER_ID=SIMMR                                    # 6-char DLT-registered sender ID

# ── App ────────────────────────────────────────────────────────────────────────
APP_ENV=development                                       # development | production
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app
